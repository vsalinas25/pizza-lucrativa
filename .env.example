# Supabase — pegue em Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # NUNCA expor com NEXT_PUBLIC_, só server-side

# Stripe — pegue em Developers > API keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=       # gerado ao criar o endpoint de webhook (ver README)
STRIPE_PIX_HABILITADO=false  # "true" só depois que Settings > Payment methods > Pix aparecer habilitado

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# VSL (opcional em dev) — URL de embed e thumbnail do vídeo de vendas
NEXT_PUBLIC_VSL_EMBED_URL=
NEXT_PUBLIC_VSL_THUMBNAIL_URL=
